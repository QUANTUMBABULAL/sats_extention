{
  "manifest_version": 3,
  "name": "Excel To Active Tab",
  "version": "1.0.0",
  "description": "Upload an Excel file in the popup and send parsed data to the active tab.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}